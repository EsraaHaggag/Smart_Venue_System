{
  "ConnectionStrings": {
    "dbcontext": "YOUR_CONNECTION_STRING"
  },

  "Jwt": {
    "Key": "YOUR_SECRET_KEY",
    "Issuer": "YOUR_ISSUER",
    "Audience": "YOUR_AUDIENCE",
    "DurationInMinutes": 60
  },

  "EmailSettings": {
    "Email": "your-email@example.com",
    "DisplayName": "Venue System",
    "Host": "smtp.example.com",
    "Port": 587,
    "Password": "YOUR_EMAIL_PASSWORD"
  },

  "OtpSettings": {
    "ExpiryInMinutes": 10,
    "MaxAttempts": 5
  },

  "AllowedHosts": "*",

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
